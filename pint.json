{
    "preset": "laravel",
    "paths": [
        "app",
        "bootstrap",
        "config",
        "database",
        "tests",
        "Modules"
    ],
    "exclude": [
        "vendor",
        "node_modules",
        "public",
        "storage",
        "bootstrap/cache"
    ],
    "rules": {
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true,
        "trailing_comma_in_multiline": true
    }
}
